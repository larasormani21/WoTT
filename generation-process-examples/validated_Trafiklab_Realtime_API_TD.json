            "properties": {
              "queryTime": {
                "type": "string",
                "format": "date-time"
              },
              "query": {
                "type": "string"
              }
            }
          },
          "stops": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "lat": {
                  "type": "number"
                },
                "lon": {
                  "type": "number"
                },
                "transport_modes": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "TRAIN",
                      "BUS"
                    ]
                  }
                },
                "alerts": {
                  "type": "array"
                }
              }
            }
          },
          "arrivals": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "scheduled": {
                  "type": "string",
                  "format": "date-time"
                },
                "realtime": {
                  "type": "string",
                  "format": "date-time"
                },
                "delay": {
                  "type": "integer"
                },
                "canceled": {
                  "type": "boolean"
                },
                "route": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "designation": {
                      "type": "string"
                    },
                    "transport_mode_code": {
                      "type": "integer"
                    },
                    "transport_mode": {
                      "type": "string",
                      "enum": [
                        "TRAIN",
                        "BUS"
                      ]
                    },
                    "direction": {
                      "type": "string"
                    },
                    "origin": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "name": {
                          "type": "string"
                        }
                      }
                    },
                    "destination": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "name": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "trip": {
                  "type": "object",
                  "properties": {
                    "trip_id": {
                      "type": "string"
                    },
                    "start_date": {
                      "type": "string",
                      "format": "date"
                    },
                    "technical_number": {
                      "type": "integer"
                    }
                  }
                },
                "agency": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "operator": {
                      "type": "string"
                    }
                  }
                },
                "stop": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "lat": {
                      "type": "number"
                    },
                    "lon": {
                      "type": "number"
                    }
                  }
                },
                "scheduled_platform": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "designation": {
                      "type": "string"
                    }
                  }
                },
                "realtime_platform": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "designation": {
                      "type": "string"
                    }
                  }
                },
                "alerts": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": "string"
                      },
                      "title": {
                        "type": "string"
                      },
                      "text": {
                        "type": "string"
                      }
                    }
                  }
                },
                "is_realtime": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      }
    }
  }
}